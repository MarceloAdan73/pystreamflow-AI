# PyStreamFlow - Variables de Entorno
# Copia este archivo como .env y completa los valores

# HuggingFace (opcional - para IA en la nube)
# Obtén tu token en: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# Supabase (opcional - para sincronización cloud)
# Obtén estas credenciales en: https://supabase.com/dashboard
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_key_here
